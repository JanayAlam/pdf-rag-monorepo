{
  "name": "@pdf-rag/server",
  "version": "0.1.0",
  "description": "",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "dev:worker": "tsx watch --env-file=.env.local src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env.local dist/index.js",
    "start:worker": "node --env-file=.env.local dist/worker.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.34",
    "@langchain/openai": "^1.3.0",
    "@langchain/qdrant": "^1.0.1",
    "@langchain/textsplitters": "^1.0.1",
    "@openai/agents": "^0.7.2",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "5.9.3",
    "langchain": "^1.2.35",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pdf-parse": "1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}